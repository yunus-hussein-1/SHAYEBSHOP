# ⚙️ انسخ هالملف باسم .env وعبّي القيم قبل التشغيل
PORT=3000

# مفتاح تشفير الجلسات — غيّره لنص عشوائي طويل جداً وسرّي
JWT_SECRET=change-me-to-a-very-long-random-secret-string

# المدير العام (بينشأ تلقائياً أول تشغيل)
ADMIN_EMAIL=owner@shayeb.shop
ADMIN_PASS=admin123
ADMIN_NAME=الإدارة العامة

# بريد متجر الشايب الرسمي (الشكاوى بتظهر باسمه)
SUPPORT_MAIL=support@shayeb.shop
